# Copy this file to "keystore.properties" in this same folder (android/).
# Never commit keystore.properties or your .keystore file.
#
# Create an upload keystore (run from android/ or adjust paths):
#   keytool -genkeypair -v -storetype PKCS12 -keystore app/release.keystore -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is relative to the android/ Gradle root (this folder).

storeFile=app/release.keystore
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
